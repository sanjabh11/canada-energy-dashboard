{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "ops:utility-bridge:evidence": "node ops/utility-connector-bridge/scripts/bridge-evidence.mjs",
    "ops:utility-bridge:tls": "bash ops/utility-connector-bridge/scripts/layer-c-tls-evidence.sh",
    "ops:utilityapi-demo:sanitize-xml": "tsx ops/utility-connector-bridge/scripts/sanitize-utilityapi-live-xml.ts",
    "test:e2e:server": "sh -c 'PORT=${PLAYWRIGHT_PHASE6_PORT:-4175}; vite --host 127.0.0.1 --port \"$PORT\" --strictPort'",
    "test:e2e:preview": "sh -c 'PORT=${PLAYWRIGHT_PHASE6_PORT:-4175}; pnpm run build && vite preview --host 127.0.0.1 --port \"$PORT\" --strictPort'",
    "build": "rm -rf node_modules/.vite-temp && tsc -b && vite build",
    "build:prod": "rm -rf node_modules/.vite-temp && tsc -b && BUILD_MODE=prod vite build",
    "check:claim-boundaries": "node scripts/check-claim-boundaries.mjs",
    "check:commercial-source": "node scripts/check-commercial-source-docs.mjs",
    "check:proof-pack-bundles": "node scripts/check-proof-pack-bundle-budgets.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:component": "playwright test",
    "test:component:headed": "playwright test --headed",
    "test:browser:phase6": "VITE_ENABLE_EDGE_FETCH=false VITE_ALLOW_LOCAL_EDGE_FETCH=false VITE_SUPABASE_EDGE_BASE= playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium",
    "test:browser:hosted:phase6": "PLAYWRIGHT_SKIP_WEBSERVER=true playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium",
    "preview": "vite preview",
    "cloud:deploy": "supabase functions deploy llm --project-ref qnymbecjgeaoxsfphrti",
    "cloud:health": "node tests/cloud_health.mjs",
    "cloud:test": "node tests/test_llm_endpoints.js",
    "verify:migration-versions": "node scripts/check-supabase-migration-versions.mjs",
    "verify:dashboard-snapshots": "node scripts/verify-dashboard-summary-snapshots.mjs",
    "test:phase4": "node tests/test_phase4_components.js",
    "cloud:all": "npm run cloud:deploy && npm run cloud:health && npm run cloud:test"
  },
  "dependencies": {
    "@paddle/paddle-js": "^1.6.1",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@stripe/stripe-js": "^8.5.3",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.0",
    "dompurify": "^3.4.7",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.364.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "redoc": "^2.5.2",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.53.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.15",
    "tailwindcss": "v3.4.16",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.3.3",
    "vite-plugin-source-identifier": "1.1.2",
    "vitest": "^3.2.4",
    "ws": "8.21.0"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit": "0.3.4",
      "ajv@>=6.0.0 <6.14.0": "6.14.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "fast-uri": "3.1.2",
      "fast-xml-parser": "5.7.0",
      "flatted": "3.4.2",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "mdast-util-to-hast": "13.2.1",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss": "8.5.15",
      "rollup": "4.59.0",
      "yaml@<1.10.3": "1.10.3",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  }
}
