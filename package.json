    "test": "vitest run",
    "test:strategy-audit-slice": "vitest run tests/unit/commercialPositioning.test.ts tests/unit/forecastBaselines.test.ts tests/unit/utilityForecasting.test.ts tests/unit/utilityForecastProofPack.test.ts tests/unit/utilityForecastBenchmarkPack.test.ts tests/unit/proofPackGates.test.ts tests/unit/regulatoryProofPack.test.ts tests/unit/pilotEvidenceRegisterValidator.test.ts tests/unit/pilotEvidenceRegisterPreview.test.ts tests/unit/pilotEvidenceArtifactPrep.test.ts tests/unit/pilotEvidenceIntakePacket.test.ts tests/unit/retainedArtifactHash.test.ts tests/unit/buyerEvidenceReadiness.test.ts tests/unit/outreachResponseLogValidator.test.ts tests/unit/githubRepoMetadata.test.ts tests/unit/productionApprovalPacket.test.ts tests/unit/unmergedBranchReadiness.test.ts tests/unit/launchEvidenceManifest.test.ts tests/unit/strategyCompletionAudit.test.ts tests/unit/corepackToolchain.test.ts tests/unit/strategySourceAnchors.test.ts tests/unit/statusPagePosture.test.ts tests/unit/byoCsvProofGenerator.test.ts tests/unit/gaIciPeakPredictor.test.ts --testTimeout=120000 --no-file-parallelism --maxWorkers=1",
