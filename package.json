    "test:component": "playwright test",
    "test:component:headed": "playwright test --headed",
    "test:browser:phase6": "VITE_ENABLE_EDGE_FETCH=false VITE_ALLOW_LOCAL_EDGE_FETCH=false VITE_SUPABASE_EDGE_BASE= PLAYWRIGHT_HTML_OUTPUT_DIR=/tmp/ceip-phase6-playwright-report PLAYWRIGHT_JSON_OUTPUT_FILE=/tmp/ceip-phase6-playwright-results.json playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium",
    "test:browser:local:proof-packs": "PLAYWRIGHT_WEBSERVER_COMMAND='pnpm run test:e2e:preview' VITE_ENABLE_EDGE_FETCH=false VITE_ALLOW_LOCAL_EDGE_FETCH=false VITE_SUPABASE_EDGE_BASE= PLAYWRIGHT_HTML_OUTPUT_DIR=/tmp/ceip-local-proof-packs-playwright-report PLAYWRIGHT_JSON_OUTPUT_FILE=/tmp/ceip-local-proof-packs-playwright-results.json playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium --grep \"route /(utility-demand-forecast|forecast-benchmarking|regulatory-filing|pilot-readiness|ga-ici-5cp|byo-csv-proof)\"",
    "test:browser:hosted:phase6": "PLAYWRIGHT_SKIP_WEBSERVER=true TEST_BASE_URL=https://canada-energy.netlify.app PLAYWRIGHT_HTML_OUTPUT_DIR=/tmp/ceip-hosted-phase6-playwright-report PLAYWRIGHT_JSON_OUTPUT_FILE=/tmp/ceip-hosted-phase6-playwright-results.json playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium",
    "test:browser:hosted:proof-packs": "PLAYWRIGHT_SKIP_WEBSERVER=true TEST_BASE_URL=https://canada-energy.netlify.app PLAYWRIGHT_HTML_OUTPUT_DIR=/tmp/ceip-hosted-proof-packs-playwright-report PLAYWRIGHT_JSON_OUTPUT_FILE=/tmp/ceip-hosted-proof-packs-playwright-results.json playwright test --config=playwright.config.ts tests/component/phase6-browser-smoke.spec.ts --project=chromium --grep \"route /(utility-demand-forecast|forecast-benchmarking|regulatory-filing|pilot-readiness|ga-ici-5cp|byo-csv-proof)\"",
