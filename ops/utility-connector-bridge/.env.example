BRIDGE_SIGNER_PORT=8787
UTILITY_BRIDGE_UPSTREAM_TLS_MODE=server_tls
SUPABASE_GREEN_BUTTON_CALLBACK_URL_BASE=https://your-project.supabase.co/functions/v1/utility-connector-green-button?action=callback
UTILITY_CONNECTOR_BRIDGE_SIGNING_KEY_ID=london-hydro-bridge-key-1
UTILITY_CONNECTOR_BRIDGE_TO_SUPABASE_SIGNING_SECRET=replace-with-strong-secret
UTILITY_CONNECTOR_SUPABASE_TO_BRIDGE_SIGNING_SECRET=replace-with-different-strong-secret
UTILITY_CONNECTOR_BRIDGE_ALLOWED_CLOCK_SKEW_SEC=300
UTILITY_CONNECTOR_BRIDGE_EXPECTED_HOST=gb.example.com
UTILITY_CONNECTOR_BRIDGE_EXPECTED_ISSUER=supabase-utility-connector-green-button
LONDON_HYDRO_TOKEN_URL=https://replace-with-london-hydro-token-endpoint
LONDON_HYDRO_FEED_URL=https://replace-with-london-hydro-feed-endpoint
LONDON_HYDRO_REVOKE_URL=https://replace-with-london-hydro-revoke-endpoint
LONDON_HYDRO_TLS_SERVER_NAME=replace-with-london-hydro-hostname
LONDON_HYDRO_CLIENT_CERT_FILE=/etc/ceip/london-hydro/client.crt
LONDON_HYDRO_CLIENT_KEY_FILE=/etc/ceip/london-hydro/client.key
