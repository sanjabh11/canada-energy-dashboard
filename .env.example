# Copy to .env.local and fill in your values (never commit real secrets)
VITE_PUBLIC_APP_URL=https://your-production-app.example.com
VITE_UTILITY_CONNECTOR_BASE_URL=https://gb.your-production-app.example.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=your-db-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (server-only, NO VITE_ prefix)

VITE_SUPABASE_EDGE_BASE=https://your-project.functions.supabase.co

VITE_DEBUG_LOGS=false
VITE_USE_STREAMING_DATASETS=true
VITE_ENABLE_WEBSOCKET=false
VITE_WEBSOCKET_URL=ws://localhost:8080
VITE_ENABLE_LIVE_STREAMING=true
VITE_ENABLE_EDGE_FETCH=true
VITE_ENABLE_UTILITYAPI_DEMO=false
VITE_ENABLE_LLM=true
VITE_LLM_PREFER_LITE=true
VITE_LLM_BASE=https://your-project.functions.supabase.co

# Operator-only UtilityAPI live demo (server-side envs / secrets)
UTILITYAPI_DEMO_LIVE_ENABLED=false
UTILITYAPI_DEMO_OPERATOR_EMAIL_ALLOWLIST=operator@example.com
UTILITYAPI_DEMO_MONTHLY_START_BUDGET=10
UTILITYAPI_DEMO_API_TOKEN=utilityapi-demo-api-token
UTILITYAPI_DEMO_FORM_UID=utilityapi-demo-form-uid
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

VITE_ENABLE_EDUCATIONAL_FEATURES=true
VITE_ENABLE_RENEWABLE_OPTIMIZATION=true
VITE_ENABLE_AESO_STREAMING=true
VITE_OPENWEATHERMAP_API_KEY=your-openweather-key

# Payment (public keys only with VITE_ prefix)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_... (server-only, NO VITE_ prefix)

VITE_WHOP_APP_ID=your-whop-app-id
VITE_WHOP_MODE=live
VITE_WHOP_CLIENT_ID=your-whop-client-id
WHOP_API_KEY=your-whop-api-key (server-only, NO VITE_ prefix)

VITE_PADDLE_CLIENT_TOKEN=your-paddle-client-token
